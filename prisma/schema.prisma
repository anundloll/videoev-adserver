generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Account ──────────────────────────────────────────────────────────────────
// Advertiser workspaces — agencies and direct brands.
model Account {
  id         String     @id @default(uuid())
  externalId String?    @unique  // e.g. 'acc-001'
  name       String
  initials   String
  industry   String
  type       String               // 'Agency' | 'Brand'
  clients    Int?                 // agency seat count
  accountId  String?              // business account ID e.g. 'AGY-00101'
  createdAt  DateTime   @default(now())
  campaigns  Campaign[]
}

// ─── Campaign ─────────────────────────────────────────────────────────────────
model Campaign {
  id             String   @id @default(uuid())
  externalId     String?  @unique  // e.g. 'cmp-001' — used for seed upsert

  // ── Display / booking fields ──────────────────────────────────────────────
  name           String?           // Human-readable campaign name
  advertiser     String?           // Brand name (denormalised for speed)
  accountId      String?           // FK to Account
  account        Account? @relation(fields: [accountId], references: [id])
  status         String   @default("pending")  // live | pending | paused
  type           String?           // direct | programmatic
  objective      String?           // awareness | consideration | conversion
  placement      String?           // station-screen | in-app | car-tablet

  // ── Flight & budget ───────────────────────────────────────────────────────
  flightStart    DateTime?
  flightEnd      DateTime?
  budget         Float    @default(0)
  spend          Float    @default(0)
  plays          Int      @default(0)
  completionRate Float    @default(0)
  pacing         Float    @default(0)
  pacingType     String?           // even | front-loaded | back-loaded
  frequencyCap   Int?

  // ── Targeting ─────────────────────────────────────────────────────────────
  networks       Json?             // string[]  e.g. ["revel","evgo"]
  cities         Json?             // string[]
  msrpTier       String?           // '$80K–$120K' | '$120K+' etc.
  vehicleModels  Json?             // string[]
  audienceSegments Json?           // string[]

  // ── Legacy / auction engine fields ───────────────────────────────────────
  brandName      String   @default("")
  sector         String   @default("")
  baseCpm        Float    @default(0)
  videoUrl       String   @default("")
  creativeUrl    String?           // Vercel Blob URL — preferred by auction engine
  conversionType String   @default("Lead_Gen")
  ctaCopy        String   @default("")
  targetingRules Json     @default("{}")
  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  trackingEvents TrackingEvent[]
}

// ─── TrackingEvent ────────────────────────────────────────────────────────────
model TrackingEvent {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  sessionId  String
  eventType  String   // 'impression' | 'start' | 'complete' | 'qr_scan'
  revenue    Float?
  createdAt  DateTime @default(now())
}

// ─── VehicleProfile ───────────────────────────────────────────────────────────
model VehicleProfile {
  id           String   @id @default(uuid())
  sessionId    String   @unique
  make         String
  model        String?
  year         Int?
  msrp         Float?
  batteryPct   Float?
  chargeKwh    Float?
  dwellMinutes Float?
  venue        String?
  detectedAt   DateTime @default(now())
}

// ─── Creative ─────────────────────────────────────────────────────────────────
model Creative {
  id             String    @id @default(uuid())
  externalId     String?   @unique  // e.g. 'cr-001'
  type           String               // 'video' | 'display'
  name           String
  advertiser     String
  duration       Int?                 // seconds
  status         String    @default("live")  // live | paused | review
  fileSize       String?
  uploaded       DateTime?
  aspectRatio    String?
  completionRate Float?
  url            String?              // S3 / CDN URL if available
  placement      String?              // for display creatives
  createdAt      DateTime  @default(now())
}

// ─── Station ─────────────────────────────────────────────────────────────────
model Station {
  id         String   @id @default(uuid())
  externalId String?  @unique  // e.g. 'st-001'
  network    String
  city       String
  location   String
  stalls     Int
  availImps  Int
  floorCpm   Float
  tier       String               // 'premium' | 'standard'
  formats    Json                 // string[]
  hwModel    String?
  createdAt  DateTime @default(now())
}
