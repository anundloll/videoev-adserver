generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id             String          @id @default(uuid())
  brandName      String
  sector         String
  baseCpm        Float
  videoUrl       String
  conversionType String
  ctaCopy        String
  targetingRules Json            // Stores bidMultipliers and affinities
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  trackingEvents TrackingEvent[] // One-to-many relationship
}

model TrackingEvent {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  sessionId  String   // Ties the event to the 10-minute charging session
  eventType  String   // e.g., 'impression', 'start', 'complete', 'qr_scan'
  revenue    Float?   // Optional: Logs the exact CPM generated by this event
  createdAt  DateTime @default(now())
}
